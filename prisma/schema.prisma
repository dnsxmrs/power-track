// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url       = env("DATABASE_URL") // pooler (runtime)
  // directUrl = env("DIRECT_URL") // direct (migrations)
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  AWAITING_DOWNPAYMENT
  ACTIVE
}

enum PaymentStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum DeviceStatus {
  ACTIVE
  OFFLINE
  WARNING
  DECOMMISSIONED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AuditEntityType {
  USER
  APPLICATION
  PAYMENT_SUBMISSION
  DEVICE
  SUPPORT_TICKET
  BRANCH
  SUBSCRIPTION_PLAN
  CLIENT_SUBSCRIPTION
  SETTINGS
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  ADMIN
  SUPERADMIN
  CLIENT
}

model User {
  id               String      @id
  name             String
  email            String
  emailVerified    Boolean     @default(false)
  image            String?
  phoneNumber      String?
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  twoFactorEnabled Boolean?    @default(false)
  role             UserRole  @default(CLIENT)
  banned           Boolean?    @default(false)
  banReason        String?
  banExpires       DateTime?
  branchId         String?
  branch           Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  clientApplications Application[] @relation("ApplicationClientUser")
  reviewedApplications Application[] @relation("ApplicationReviewedBy")
  clientSubscriptions ClientSubscription[]
  devices          Device[]
  paymentSubmissions PaymentSubmission[] @relation("UserPaymentSubmissions")
  reviewedPaymentSubmissions PaymentSubmission[] @relation("PaymentReviewedBy")
  submittedTickets SupportTicket[] @relation("SupportTicketRequester")
  assignedTickets  SupportTicket[] @relation("SupportTicketAssignee")
  ticketMessages   SupportTicketMessage[]
  requestLogs      RequestLog[]
  auditLogs        AuditLog[]
  notificationSettingsUpdated SystemNotificationSetting[]

  @@unique([email])
  @@map("user")
}

model Branch {
  id           String       @id @default(cuid())
  name         String
  code         String       @unique
  address      String?
  city         String?
  province     String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  status       BranchStatus @default(ACTIVE)
  notes        String?
  users        User[]
  devices      Device[]
  applications Application[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@map("branch")
}

model SubscriptionPlan {
  id                  String              @id @default(cuid())
  name                String
  slug                String              @unique
  monthlyPrice        Int
  deviceCap           Int
  description         String?
  features            Json?
  isPopular           Boolean             @default(false)
  isActive            Boolean             @default(true)
  applications        Application[]
  clientSubscriptions  ClientSubscription[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([name])
  @@map("subscription_plan")
}

model Application {
  id                     String             @id @default(cuid())
  ticketNumber           String             @unique
  fullName               String
  email                  String
  phoneNumber            String
  planId                 String
  plan                   SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  deviceCount            Int
  specialRequirements    String?
  proofOfBillingFileName  String?
  proofOfBillingUrl      String?
  proofOfBillingMimeType String?
  validIdFrontFileName   String?
  validIdFrontUrl       String?
  validIdFrontMimeType  String?
  validIdBackFileName    String?
  validIdBackUrl        String?
  validIdBackMimeType   String?
  status                 ApplicationStatus  @default(SUBMITTED)
  statusReason           String?
  reviewedById           String?
  reviewedBy             User?              @relation("ApplicationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt             DateTime?
  approvedAt             DateTime?
  rejectedAt             DateTime?
  submittedAt            DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  branchId               String?
  branch                 Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  clientUserId           String?            @unique
  clientUser             User?              @relation("ApplicationClientUser", fields: [clientUserId], references: [id], onDelete: SetNull)
  paymentSubmissions     PaymentSubmission[]
  createdSubscription    ClientSubscription? @relation("ApplicationToSubscription")

  @@index([email])
  @@index([status])
  @@index([submittedAt])
  @@map("application")
}

model ClientSubscription {
  id                  String              @id @default(cuid())
  userId              String              @unique
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId              String
  plan                SubscriptionPlan    @relation(fields: [planId], references: [id], onDelete: Restrict)
  sourceApplicationId String?             @unique
  sourceApplication   Application?        @relation("ApplicationToSubscription", fields: [sourceApplicationId], references: [id], onDelete: SetNull)
  deviceCap           Int
  monthlyPrice        Int
  billingCycleDay     Int?
  nextDueDate         DateTime?
  status              String              @default("active")
  startedAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  devices             Device[]
  paymentSubmissions  PaymentSubmission[]

  @@index([status])
  @@index([nextDueDate])
  @@map("client_subscription")
}

model PaymentSubmission {
  id               String              @id @default(cuid())
  referenceNumber  String              @unique
  billingMonth     String
  amount           Int
  proofFileName    String?
  proofFileUrl     String?
  proofMimeType    String?
  status           PaymentStatus       @default(PENDING_VERIFICATION)
  submittedAt      DateTime            @default(now())
  reviewedAt       DateTime?
  reviewedById     String?
  reviewedBy       User?               @relation("PaymentReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote       String?
  userId           String?
  user             User?               @relation("UserPaymentSubmissions", fields: [userId], references: [id], onDelete: SetNull)
  subscriptionId   String?
  subscription     ClientSubscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  applicationId    String?
  application      Application?        @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([userId, billingMonth])
  @@index([status])
  @@index([referenceNumber])
  @@map("payment_submission")
}

model Device {
  id               String             @id @default(cuid())
  serialNumber     String             @unique
  name             String
  locationLabel    String?
  tags             Json?
  status           DeviceStatus       @default(ACTIVE)
  firmwareVersion  String?
  lastSeenAt       DateTime?
  installedAt      DateTime?
  decommissionedAt DateTime?
  branchId         String?
  branch           Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userId           String?
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscriptionId   String?
  subscription     ClientSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status])
  @@index([branchId])
  @@index([userId])
  @@map("device")
}

model SupportTicket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique
  name         String
  email        String
  subject      String
  category     String
  message      String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(NORMAL)
  userId       String?
  user         User?          @relation("SupportTicketRequester", fields: [userId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?          @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  replies      SupportTicketMessage[]

  @@index([status])
  @@index([category])
  @@index([assignedToId])
  @@map("support_ticket")
}

model SupportTicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String?
  message    String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([ticketId])
  @@map("support_ticket_message")
}

model AuditLog {
  id         String          @id @default(cuid())
  actorId    String?
  actor      User?           @relation(fields: [actorId], references: [id], onDelete: SetNull)
  entityType AuditEntityType
  entityId   String
  action     String
  beforeState Json?
  afterState  Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime        @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_log")
}

model SystemNotificationSetting {
  id                    String   @id @default(cuid())
  emailEnabled          Boolean  @default(true)
  pushEnabled           Boolean  @default(true)
  inAppEnabled          Boolean  @default(true)
  newApplicationAlerts  Boolean  @default(true)
  paymentAlerts         Boolean  @default(true)
  deviceAlerts          Boolean  @default(true)
  ticketAlerts          Boolean  @default(true)
  quietHoursStart       String?
  quietHoursEnd         String?
  updatedById           String?
  updatedBy             User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("system_notification_setting")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model RequestLog {
  id        String   @id @default(cuid())
  method    String
  path      String
  query     Json?
  headers   Json
  payload   Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@map("request_log")
}

model Settings {
  id                      String   @id @default(cuid())
  pricePerKilowattHour    Float
  platformName            String?
  supportEmail            String?
  maintenanceMode         Boolean  @default(false)
  downpaymentAmountPerDevice Int  @default(1500)
  loginLockoutThreshold    Int      @default(5)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("settings")
}
